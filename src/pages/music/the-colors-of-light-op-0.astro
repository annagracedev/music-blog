---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";

// Images
import placeholderImg from "@assets/images/blog/roman-kraft-VfP_-Rmnhk4-unsplash.jpg";


const optimizedPlaceholder = await getImage({
	src: placeholderImg,
	format: "webp",
});

const cover = "/src/assets/images/blog/roman-kraft-VfP_-Rmnhk4-unsplash.jpg";

//ok so playlist autoplay does not actually work
---

<script is:inline src="https://ajax.googleapis.com/ajax/libs/jquery/1.7.2/jquery.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/mediaelement/7.0.7/mediaelementplayer.min.css" rel="stylesheet">
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/mediaelement/7.0.7/mediaelement-and-player.min.js"></script>
<link href="/src/styles/playlist.css" rel="stylesheet"/>
<script is:inline src="/src/js/playlist.js"></script>

<BaseLayout
	title="Welcome"
	description="Your new Astro site"
	heroImage={optimizedPlaceholder}
>
	<main id="main">
		<section id="welcome">
			<div class="cs-container">
				<div class="cs-content">
					<h1>The Colors of Light, Op. 0</h1>
				</div>
				<div class="audio-player">
						<h1>Demo</h1>
						<img class="cover" src={cover} alt="">
						<audio id="audio-player" controls>
							<source src="/src/assets/mp3s/The Colors of Light/01 - Nightshade.mp3" title="Nightshade (Op. 0, No. 1)" type="audio/mp3" />
							<source src="/src/assets/mp3s/The Colors of Light/02 - Retrograde Heart.mp3" title="Retrograde Heart (Op. 0, No. 2)" type="audio/mp3" />
							<source src="/src/assets/mp3s/The Colors of Light/03 - Crow's Justice.mp3" title="Crow’s Justice (Op. 0, No. 3)" type="audio/mp3" />
							<source src="/src/assets/mp3s/The Colors of Light/04 - Aria.mp3" title="Aria (Op. 0, No. 4)" type="audio/mp3" />
							<source src="/src/assets/mp3s/The Colors of Light/05 - Fantasy.mp3" title="Fantasy (Op. 0, No. 5)" type="audio/mp3" />
							<source src="/src/assets/mp3s/The Colors of Light/06 - Galanthus.mp3" title="Galanthus (Op. 0, No. 6)" type="audio/mp3" />
							<source src="/src/assets/mp3s/The Colors of Light/07 - DAYBREAK.mp3" title="DAYBREAK (Op. 0, No. 7)" type="audio/mp3" />
							<source src="/src/assets/mp3s/The Colors of Light/08 - All the Lights.mp3" title="All the Lights (Op. 0, No. 8)" type="audio/mp3" />
						</audio>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<script is:inline>
	window.addEventListener('load', () => {
			new MediaElementPlayer('audio-player', {
				iconSprite: '/src/styles/mejs-controls.svg',
				features: ['playlist', 'prevtrack', 'playpause', 'nexttrack', 'current', 'progress', 'duration', 'volume']
			});
	});
</script>

<style lang="less">
	#welcome {
		padding: (100/16rem) 1rem 1rem;

		.cs-container {
			max-width: 1280px;
			margin: 0 auto;
		}

		.cs-content {
			max-width: 800px;
			margin: 0 auto;
			text-align: center;

			h1 {
				margin-bottom: 24px;
				font-size: clamp(2rem, 5vw, 3rem);
			}

			p {
				margin-bottom: 16px;
				font-size: 1.125rem;
				line-height: 1.6;
			}

			code {
				padding: 2px 8px;
				background: #f4f4f4;
				border-radius: 4px;
				font-family: monospace;
			}

			a {
				color: var(--link);
				text-decoration: underline;

				&:hover {
					opacity: 0.8;
				}
			}
		}
	}

	/* Dark mode */
	@media only screen and (prefers-color-scheme: dark) {
		#welcome {
			.cs-content {
				code {
					background: #2a2a2a;
				}
			}
		}
	}

	body.dark-mode {
		#welcome {
			.cs-content {
				code {
					background: var(--dark);
				}
				a {
					color: var(--linkLight);
				}
			}
		}
	}

	// MARK: Audio player
	body {
			.audio-player img {
			height: auto;
			width: 10rem;
		}
	}
</style>
