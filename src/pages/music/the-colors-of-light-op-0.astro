---
// Utils
import { getImage } from "astro:assets";
import "@styles/playlist.css";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";

// Images
import coverImg from "@assets/images/blog/roman-kraft-VfP_-Rmnhk4-unsplash.webp";

const cover = await getImage({ src: coverImg, format: "webp" });

---

<script is:inline src="https://ajax.googleapis.com/ajax/libs/jquery/1.7.2/jquery.min.js"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/mediaelement/7.0.7/mediaelementplayer.min.css" rel="stylesheet">
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/mediaelement/7.0.7/mediaelement-and-player.min.js"></script>
<script is:inline src="/playlist.js"></script>

<BaseLayout
	title="The Colors of Light, Op. 0"
	description="Suite for Bb clarinet, harp, piano, violoncello, and double bass."
>
	<main id="main">
		<section id="content">
			<div class="cs-container">
				<div class="cs-content">
					<h1>The Colors of Light, Op. 0 (2020, rev. 2025)</h1>
					<h2>Suite for Bb clarinet, harp, piano, violoncello, and double bass</h2>
					<ul><li>No. 1, Nightshade</li>
					<li>No. 2. Retrograde Heart</li>
					<li>No. 3, Crow’s Justice</li>
					<li>No. 4, Aria</li>
					<li>No. 5, Fantasy</li>
					<li>No. 6, Galanthus</li>
					<li>No. 7, DAYBREAK</li>
					<li>No. 8, All the Lights</li></ul>
				</div>
				<div class="audio-player-border">
					<div class="audio-player-wrapper">
						<div class="image-wrapper">
							<img class="cover" src=`${cover}` alt="">
						</div>
						<audio id="audio-player" controls>
							
						</audio>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<script is:inline>

</script>

<script is:inline>
	document.addEventListener('astro:page-load', () => {
			new MediaElementPlayer('audio-player', {
				iconSprite: '/mejs-controls.svg',
				features: ['playlist', 'prevtrack', 'playpause', 'nexttrack', 'current', 'progress', 'duration', 'volume', ],
				playlist: [ {src:"/assets/mp3s/The Colors of Light/01 - Nightshade.mp3", title:"Nightshade (Op. 0, No. 1)", type:"audio/mp3"}, 
					{src:"/assets/mp3s/The Colors of Light/02 - Retrograde Heart.mp3", title:"Retrograde Heart (Op. 0, No. 2)", type:"audio/mp3"}, 
					{src:"/assets/mp3s/The Colors of Light/03 - Crow's Justice.mp3", title:"Crow’s Justice (Op. 0, No. 3)", type:"audio/mp3"}, 
					{src:"/assets/mp3s/The Colors of Light/04 - Aria.mp3", title:"Aria (Op. 0, No. 4)", type:"audio/mp3"}, 
					{src:"/assets/mp3s/The Colors of Light/05 - Fantasy.mp3", title:"Fantasy (Op. 0, No. 5)", type:"audio/mp3"}, 
					{src:"/assets/mp3s/The Colors of Light/06 - Galanthus.mp3", title:"Galanthus (Op. 0, No. 6)", type:"audio/mp3"}, 
					{src:"/assets/mp3s/The Colors of Light/07 - DAYBREAK.mp3", title:"DAYBREAK (Op. 0, No. 7)", type:"audio/mp3"}, 
					{src:"/assets/mp3s/The Colors of Light/08 - All the Lights.mp3", title:"All the Lights (Op. 0, No. 8)", type:"audio/mp3"} ],
					currentMessage: 'Now Playing: '
			});
			
	});
</script>

<style lang="less" define:vars={{cover}}>
	#content {
		padding: (100/16rem) 1rem 1rem;

		.cs-container {
			width: 100%;
			max-width: 1280px;
			margin: auto;
			display: flex;
			flex-direction: row-reverse;
			align-items: flex-start;
			justify-content: flex-start;
			
			gap: (80/16rem);
			margin-top: clamp(2rem, 6.3vw, 3rem);
			margin-bottom: clamp(2rem, 6.3vw, 3rem);
		}
		.cs-content {
			max-width: 800px;
			margin: 0 auto;
			text-align: left;
			display: flex;
			flex-direction: column;
			flex-grow: 1;
			margin-bottom: clamp(1.5rem, 6.3vw, 2rem); //subtract p margin
			p {
				line-height: 2rem;
				margin-bottom: 1rem;
			}
			h1 {
				margin-bottom: 1rem;
				font-size: clamp(1.5rem, 5vw, 2rem);
			}
			h2 {
				margin-bottom: 1rem;
				font-size: clamp(1.25rem, 5vw, 1.5rem);
			}
			li {
				list-style: none;
				line-height: 2rem;
				margin-bottom: 1rem;
			}
		}
	}
		// MARK: Audio player
	.audio-player-wrapper img {
				height: auto;
				width: 10rem;
			}
	.audio-player-wrapper {
		max-width: 400px;
		display: flex;
		flex-direction: column;
		align-items: center;
		font-family: 'Overpass', sans-serif;
		background-image: var(--cover);
		background-color: #000;
		-webkit-backdrop-filter: blur(10px);
		backdrop-filter: blur(10px);
	}
	.audio-player-border {
		box-shadow: var(--boxShadow); 
		margin-bottom: clamp(1.5rem, 6.3vw, 2rem); //subtract p margin
	}

@media only screen and (min-width: 64rem) {
    #content
			.cs-container {
        max-width: 80rem;
		}
	}
</style>
