---

// Utils
import { Icon } from "astro-icon/components";
import { isCurrentPage, getDropdownId } from "@js/utils.js";

// Components
import DarkModeToggle from "@components/DarkModeToggleMDI.astro";
import Logo from "@components/Logo.astro";

// Data
import navData from "@data/navData.json";
;

---
<header id="cs-navigation">
	<div class="cs-container">
		<!--Nav Logo-->
		<a href="/" class="cs-logo" aria-label="Return to home page">
			<Logo />
			<span id="logo-text">Anna Grace</span>
		</a>
		<!--Navigation List-->
		<nav class="cs-nav" aria-label="main navigation">
			<div class="menu-ul-wrapper" id="menu-ul-wrapper">
				<ul id="cs-expanded" class="cs-ul">
					{
						navData.map((entry) => (
							<li
								class:list={[
									"cs-li",
									{ "cs-dropdown": entry.children?.length > 0 },
								]}
							>
								{entry.children?.length > 0 ? (
									// If entry has children in navData.json, create a button and a dropdown icon
									<button
										id={getDropdownId(entry.key)}
										aria-expanded="false"
										aria-haspopup="menu"
										class:list={[
											"cs-li-nav cs-dropdown-toggle",
											{ "menu-active": Astro.url.pathname.includes(entry.url) },
										]}
									>
										<a
										href={entry.url}
										class="cs-li-nav"
										aria-current={isCurrentPage(Astro.url.pathname, entry.url)}
									>
										{entry.key}</a>
										<Icon name="mdi--caret" class="cs-drop-icon" />
									</button>
								) : (
									// If entry does not have children in navData.json, create an anchor
									<a
										href={entry.url}
										class:list={[
											"cs-li-link",
											{ "menu-active": Astro.url.pathname === entry.url },
										]}
										aria-current={isCurrentPage(Astro.url.pathname, entry.url)}
									>
										{entry.key}
									</a>
								)}

								{entry.children?.length > 0 && (
									// If entry has children in navData.json, create a drop down menu
									<ul
										class="cs-drop-ul"
										aria-labelledby={getDropdownId(entry.key)}
									>
										{entry.children.map((child) => (
											<li class="cs-drop-li">
												<a
													href={child.url}
													class="cs-li-link cs-drop-link"
													aria-current={isCurrentPage(
														Astro.url.pathname,
														child.url,
													)}
												>
													{child.key}
												</a>
											</li>
										))}
									</ul>
								)}
							</li>
						))
					}
					<li class="cs-li cs-hide-on-desktop">
						<a
							href="/contact/"
							class:list={[
								"cs-li-link",
								{ "menu-active": Astro.url.pathname === "/contact/" },
							]}
							aria-current={isCurrentPage(Astro.url.pathname, "/contact/")}
						>
							Contact
						</a>
					</li>
				</ul>
			</div>
		</nav>
		<a href="/contact/" class="cs-button-solid cs-nav-button">Contact</a>
		<DarkModeToggle />
		<nav class="cs-nav" aria-label="main navigation">
			<button
				class="cs-toggle"
				id="cs-toggle"
				aria-expanded="false"
				aria-controls="menu-ul-wrapper"
				aria-haspopup="menu"
				aria-label="mobile menu toggle"
			>
				<span class="menu-box" aria-hidden="true">
					<span class="menu-line menu-line1" aria-hidden="true"></span>
					<span class="menu-line menu-line2" aria-hidden="true"></span>
					<span class="menu-line menu-line3" aria-hidden="true"></span>
				</span>
			</button>
		</nav>
	</div>
</header>

<style lang="less">

	//Mobile - 1023px
	@media only screen and (max-width: 63.9375rem) {
		body {
			&.menu-open {
				overflow: hidden;
			}
		}

		#logo-text {
			display: none;
		}

		#cs-navigation {
			width: 100%;
			box-sizing: border-box;
			padding: (12/16rem) (16/16rem);
			background-color: #fff;
			box-shadow: var(--boxShadow);
			position: fixed;
			z-index: 10000;

			&.menu-active {
				&:before {
					width: 100%;
					opacity: 1;
				}

				.menu-ul-wrapper {
					opacity: 1;
					visibility: visible;
					min-width: 100%;
					@media (prefers-reduced-motion: no-preference) {
						transform: scaleY(1);
						transition-delay: 0.2s;
					}
				}

				.cs-li {
					opacity: 1;
					transform: translateX(0);
					width: 100%;
				}

				.cs-li-nav {
					text-decoration: none;
					color: var(--bodyTextColor);
					font-size: clamp(1rem, 2.5vw, 1.5rem);
				}
			
			}

			.cs-container {
				width: 100%;
				display: flex;
				justify-content: flex-end;
				align-items: center;
			}

			.cs-logo {
				width: 40%;
				max-width: (146/16rem);
				height: 100%;
				margin: 0 auto 0 0;
				/* prevents padding from affecting height and width */
				box-sizing: border-box;
				padding: 0;
				display: flex;
				justify-content: center;
				align-items: center;
				z-index: 10;

				text-decoration: none;
				font-family: "Overpass", sans-serif;
				/* 16px - 24px */
				font-size: clamp(1rem, 1.5vw, 1.5rem);
				font-style: normal;
				color: var(--bodyTextColor);

				#logo {
					width: 70%;
					height: 70%;
					/* ensures the image never overflows the container. It stays contained within it's width and height and expands to fill it then stops once it reaches an edge */
					object-fit: contain;
					/* places the image to the left edge of the parent */
					object-position: left;
				}
			}

			.cs-toggle {
				/* 44px - 48px */
				width: clamp(2.75rem, 6vw, 3rem);
				height: clamp(2.75rem, 6vw, 3rem);
				margin: 0 0 0 auto;
				background-color: transparent;
				border: none;
				border-radius: (4/16rem);
				display: flex;
				justify-content: center;
				align-items: center;
			}

			@media (prefers-reduced-motion: no-preference) {
				.menu-active {
					.menu-line1 {
						top: 50%;
						transform: translate(-50%, -50%) rotate(225deg);
					}

					.menu-line2 {
						top: 50%;
						transform: translate(-50%, -50%) translateY(0) rotate(-225deg);
						transform-origin: center;
					}

					.menu-line3 {
						opacity: 0;
						bottom: 100%;
					}
				}
			}

			.menu-box {
				/* 24px - 28px */
				width: clamp(1.5rem, 2vw, 1.75rem);
				/* 14px - 16px */
				height: clamp(0.875rem, 1.5vw, 1rem);
				position: relative;
			}

			.menu-line {
				width: 100%;
				height: 2px;
				background-color: #000;
				border-radius: 2px;
				position: absolute;
				left: 50%;
				transform: translateX(-50%);
			}

			.menu-line1 {
				top: 0;

				transition:
					transform 0.5s,
					top 0.3s,
					left 0.3s;
				animation-duration: 0.7s;
				animation-timing-function: ease;
				animation-direction: normal;
				animation-fill-mode: forwards;
				transform-origin: center;
			}

			.menu-line2 {
				top: 50%;
				transform: translateX(-50%) translateY(-50%);
				transition:
					top 0.3s,
					left 0.3s,
					transform 0.5s;
				animation-duration: 0.7s;
				animation-timing-function: ease;
				animation-direction: normal;
				animation-fill-mode: forwards;
			}

			.menu-line3 {
				bottom: 0;
				transition:
					bottom 0.3s,
					opacity 0.3s;
			}

			.cs-drop-ul {
				list-style: none;
				width: 100%;
				height: 0;
				margin: 0;
				box-sizing: border-box;
				padding: 0 (24/16rem) 0 (24/16rem);
				opacity: 0;
				display: flex;
				visibility: hidden;
				flex-direction: column;
				justify-content: flex-start;
				align-items: flex-end;
				gap: (12/16rem);
				overflow: hidden;
				transform: scale(0);
				transition:
					padding 0.3s,
					margin 0.3s,
					height 0.3s,
					opacity 0.3s,
					transform 0.3s,
					visibility 0.3s;
				transform-origin: top;
			}

			.cs-dropdown {
				position: relative;

				&.menu-active {
					.cs-drop-ul {
						height: auto;
						margin: (12/16rem) 0 0 0;
						padding: (24/16rem);
						opacity: 1;
						visibility: visible;
						transform: scale(1);
						align-items: center;
					}

					.cs-drop-link {
						text-decoration: none;
						opacity: 1;
					}

					.cs-drop-icon {
						transform: rotate(0);
					}
				}
			}

			.cs-drop-icon {
				width: (15/16rem);
				height: auto;
				display: inline-block;
				color: inherit;
				transform: rotate(180deg);
				transition: 0.3s;
			}

			.menu-ul-wrapper {
				height: 100vh;
				background-color: #fff;
				box-shadow: var(--boxShadow); /*inset rgba(0, 0, 0, 0.2) 0rem 0.5rem 1.5rem;*/
				opacity: 0;
				visibility: hidden;
				position: absolute;
				top: 100%;
				right: 0;
				left: auto;
				z-index: -1;
				overflow: hidden;
				@media (prefers-reduced-motion: no-preference) {
					transform: scaleY(0);
					transition:
						transform 0.4s,
						opacity 0.3s;
					transform-origin: top right;
				}
			}

			.cs-ul {
				width: auto;
				min-width: 40%;
				height: 65vh;
				margin: 0;
				/* 28px - 40px */
				padding: (48/16rem) clamp(1.75rem, 3vw, 2.5rem) (32/16rem) (70/16rem);
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
				align-items: flex-end;
				gap: (20/16rem);
				overflow: scroll;
			}

			.cs-li {
				text-align: center;
				list-style: none;
				width: 100%;
				margin-right: 0;
				opacity: 0;
				/* transition from these values */
				transform: translateX(-40/16rem);
				transition:
					transform 0.6s,
					opacity 0.9s;

				@media (prefers-reduced-motion: no-preference) {
					&:nth-of-type(1) {
						transition-delay: 0.05s;
					}
					&:nth-of-type(2) {
						transition-delay: 0.1s;
					}
					&:nth-of-type(3) {
						transition-delay: 0.15s;
					}
					&:nth-of-type(4) {
						transition-delay: 0.2s;
					}
					&:nth-of-type(5) {
						transition-delay: 0.25s;
					}
					&:nth-of-type(6) {
						transition-delay: 0.3s;
					}
					&:nth-of-type(7) {
						transition-delay: 0.35s;
					}
					&:nth-of-type(8) {
						transition-delay: 0.4s;
					}
					&:nth-of-type(9) {
						transition-delay: 0.45s;
					}
				}
			}

			.cs-li-link {
				/* 16px - 24px */
				font-size: clamp(1rem, 2.5vw, 1.5rem);
				color: inherit;
				line-height: 1.5em;
				text-decoration: none;
				margin: 0;
				display: inline-block;
				position: relative;
				transition: opacity 0.3s;

				&:before {
					/* active state underline */
					content: "";
					width: 100%;
					height: 1px;
					background: var(--bodyTextColor);
					opacity: 1;
					display: none;
					position: absolute;
					bottom: (-2/16rem);
					left: 0;
				}

				&.menu-active {
					&:before {
						display: block;
					}
				}
			}

		.cs-li-link {
			&.cs-drop-link {
				/* 14px - 16px */
				font-size: clamp(0.9rem, 2vw, 1.25rem);
				color: var(--bodyTextColor);
			}
		}

			.cs-dropdown-toggle {
				background-color: transparent;
				border: none;
				appearance: none;
			}

			.cs-button-solid {
				display: none;
			}
		}
	}

	/* Mobile Dark Mode */
	@media only screen and (max-width: 63.9375rem) {
		body.dark-mode {
			#cs-navigation {
				background-color: #000;

				.cs-dropdown {
					font-size: clamp(1rem, 2.5vw, 1.5rem);
					.cs-li-nav {
						font-size: clamp(1rem, 2.5vw, 1.5rem);
						color: var(--bodyTextColorWhite);
						text-decoration: none;
					}
				}

				.cs-logo {
					/* makes it white */
					// filter: grayscale(1) brightness(1000%);
					color: var(--bodyTextColorWhite);
				}

				.menu-line {
					background-color: #fff;
				}

				.menu-ul-wrapper {
					background-color: var(--primaryLight);
				}

				.cs-li-link {
					color: var(--bodyTextColorWhite);
				}
			}
		}
	}


	//Desktop - 1024px
	@media only screen and (min-width: 64rem) {
		#cs-navigation {

			.cs-dropdown {
				position: relative;
				&:hover,
				&.menu-active {
					cursor: pointer;
					.cs-drop-ul {
						opacity: 1;
						visibility: visible;
						transform: scaleY(1);
					}

					.cs-drop-li {
						opacity: 1;
						transform: translateY(0);
					}
				}
			}

			.cs-dropdown:has(.cs-drop-icon) {
				display: flex;
				align-items: center;
				&:hover {
					will-change: transform;
					.cs-drop-icon {
						transform: rotate(0);
					}
				}
			}

			.cs-drop-icon {
				width: (15/16rem);
				height: auto;
				display: inline-block;
				color: inherit;
				transform: rotate(180deg);
				@media (prefers-reduced-motion: no-preference) { 
					transition: transform 0.3s; 
				}
			}

			.cs-drop-ul {
				min-width: (200/16rem);
				margin: 0;
				padding: 0;
				background-color: #fff;
				box-shadow: var(--boxShadow);
				opacity: 0;
				visibility: hidden;
				text-align: center;
				align-items: center;
				/* if you have 8 or more links in your dropdown nav, uncomment the columns property to make the list into 2 even columns. Change it to 3 or 4 if you need extra columns. Then remove the transition delays on the cs-drop-li so they don't have weird scattered animations */
				// columns: 2;
				position: absolute;
				top: 100%;
				z-index: -100;
				overflow: hidden;
				transform: scaleY(0);
				transition:
					transform 0.3s,
					visibility 0.3s,
					opacity 0.3s;
				transform-origin: top;
			}

			.cs-drop-li {
				font-size: (16/16rem);
				text-decoration: none;
				list-style: none;
				text-align: inherit;
				width: 100%;
				height: auto;
				color: var(--bodyTextColor);
				opacity: 0;
				display: block;
				transform: translateY(-10/16rem);
				transition:
					// opacity 0.6s,
					transform 0.6s;

				&:nth-of-type(1) {
					transition-delay: 0.05s;
				}
				&:nth-of-type(2) {
					transition-delay: 0.1s;
				}
				&:nth-of-type(3) {
					transition-delay: 0.15s;
				}
				&:nth-of-type(4) {
					transition-delay: 0.2s;
				}
				&:nth-of-type(5) {
					transition-delay: 0.25s;
				}
				&:nth-of-type(6) {
					transition-delay: 0.3s;
				}
				&:nth-of-type(7) {
					transition-delay: 0.35s;
				}
				&:nth-of-type(8) {
					transition-delay: 0.4s;
				}
				&:nth-of-type(9) {
					transition-delay: 0.45s;
				}
				&:nth-of-type(10) {
					transition-delay: 0.5s;
				}
				&:nth-of-type(11) {
					transition-delay: 0.55s;
				}
				&:nth-of-type(12) {
					transition-delay: 0.6s;
				}
				&:nth-of-type(13) {
					transition-delay: 0.65s;
				}
			}

			.cs-li-nav {
				/* 14px - 16px */
				
				font-size: clamp(1rem, 2.5vw, 1.5rem);
				line-height: 1.5em;
				text-decoration: none;
				margin: 0;
				color: var(--bodyTextColor);
			}

			.cs-li-link {
				&.cs-drop-link {
					background-color: #fff;
					font-size: (16/16rem);
					line-height: 1.5em;
					text-decoration: none;
					list-style: none;
					white-space: nowrap;
					width: 100%;
					/* prevents padding from affecting height and width */
					box-sizing: border-box;
					padding: (12/16rem);
					color: var(--bodyTextColor);
					display: block;
					&:hover {
							background-color: #fff;
						}
					&:hover {
							&:before {
							width: 100%;
							}
						}
					&:before {
							/* active state underline on hover over links */
							content: "";
							width: 0%;
							height: 1px;
							background: var(--bodyTextColor);
							opacity: 1;
							display: block;
							position: absolute;
							bottom: 0;
							left: 0;
							@media (prefers-reduced-motion: no-preference) {
								transition: width 0.3s;
							}
						}
					}
				}

			.cs-dropdown-toggle {
				background-color: transparent;
				border: none;
				appearance: none;
			}
		}
	}

		//Small Desktop - 1024px
	@media only screen and (min-width: 64rem) {
		#cs-navigation {
			/* remove the font family so the Stitch inherits the fonts from your global stylesheet */
			// font-family: "Roboto", "Arial", sans-serif;
			font-style: normal;
			width: 100%;
			/* prevents padding from affecting height and width */
			box-sizing: border-box;
			padding: 0 (16/16rem);
			background-color: #fff;
			box-shadow: var(--boxShadow);
			position: fixed;
			z-index: 10000;

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				display: flex;
				justify-content: flex-end;
				align-items: center;
				gap: (24/16rem);
			}

			.cs-toggle {
				display: none;
			}

			.cs-logo {
				width: 18.4%;
				max-width: (350/16rem);
				height: (65/16rem);
				/* margin-right auto pushes everything away from it to the right */
				margin: 0 auto 0 0;
				padding: 0;
				display: flex;
				justify-content: center;
				align-items: center;
				z-index: 100;

				img {
					width: 100%;
					height: 100%;
					/* ensures the image never overflows the container. It stays contained within it's width and height and expands to fill it then stops once it reaches an edge */
					object-fit: contain;
				}

				//text formatting
				text-decoration: none;
				font-family: "Overpass", sans-serif;
				/* 24px - 32px */
				font-size: clamp(1.5rem, 1.5vw, 2rem);
				color: var(--bodyTextColor);
			}

			.cs-ul {
				width: 100%;
				margin: 0;
				padding: 0;
				display: flex;
				justify-content: flex-start;
				align-items: center;
				/* 20px - 36px */
				gap: 0.25rem;
			}

			.cs-li {
				list-style: none;
				padding: (32/16rem) (16/16rem);
				/* prevent flexbox from squishing it */
				flex: none;
				font-family: "Overpass", sans-serif;
				font-weight: 400;
			}

			.cs-li-nav {
				/* 14px - 16px */
				font-size: clamp(0.875rem, 1vw, 1rem);
				line-height: 1.5em;
				text-decoration: none;
				margin: 0;
				color: var(--bodyTextColor);
			}

			.cs-li-link {
				/* 14px - 16px */
				font-size: clamp(0.875rem, 1vw, 1rem);
				line-height: 1.5em;
				text-decoration: none;
				margin: 0;
				color: var(--bodyTextColor);
				display: block;
				position: relative;
				&:hover {
					&:before {
						width: 100%;
					}
				}

				&:before {
					/* active state underline on hover over links */
					content: "";
					width: 0%;
					height: 1px;
					background: var(--bodyTextColor);
					opacity: 1;
					display: block;
					position: absolute;
					bottom: (-2/16rem);
					left: 0;
					@media (prefers-reduced-motion: no-preference) {
						transition: width 0.3s;
					}
				}
			}
		}
	}

	//Desktop Dark Mode
// idk why dropdown li in dark mode is suddenly white
//also need active underline under folder

	@media only screen and (min-width: 0rem) {
		body.dark-mode {
			#cs-navigation {
				box-shadow: var(--boxShadow);

				.cs-li-nav {
				color: var(--bodyTextColorWhite);
			}
				.cs-li-link {
				&:before {
					/* active state underline */
					background: var(--bodyTextColorWhite);
				}
			}

			.cs-li-link {
				&.cs-drop-link {
					&:hover {
						background-color: var(--primaryLight);
					}
				}
			}

				.cs-drop-icon {
					/* turns it white */
					filter: grayscale(1) brightness(1000%);
				}
			}
		}
	}

	@media only screen and (min-width: 64rem) {
		body.dark-mode {
