<a href="/rss.xml" aria-label="rss" id="rss-icon">
	<svg 
		class="rss"
		xmlns="http://www.w3.org/2000/svg" 
		viewBox="0 0 24 24">
		<title>rss</title>
		<path d="M6.18,15.64A2.18,2.18 0 0,1 8.36,17.82C8.36,19 7.38,20 6.18,20C5,20 4,19 4,17.82A2.18,2.18 0 0,1 6.18,15.64M4,4.44A15.56,15.56 0 0,1 19.56,20H16.73A12.73,12.73 0 0,0 4,7.27V4.44M4,10.1A9.9,9.9 0 0,1 13.9,20H11.07A7.07,7.07 0 0,0 4,12.93V10.1Z" />
	</svg>
</a>



<style lang="less">

	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		body.dark-mode {
			#rss-icon {
				.rss {
					fill: #fff;
					@media (prefers-reduced-motion: no-preference) {transition: all 0.3s;}
				}
			}
		}

		#rss-icon {
			width: (48/16rem);
			height: (48/16rem);
			padding: 0;
			background: transparent;
			border: none;
			display: block;
			position: absolute;
			top: (10/16rem);
			right: (116/16rem);
			z-index: 1000;
			overflow: hidden;

			img,
			svg {
				width: (20/16rem);
				height: (20/16rem);
				//center image inside button
				position: absolute;
				top: 50%;
				left: 50%;
				transform: translate(-50%, -50%);
				pointer-events: none;
			}

			.rss {
				fill: #000; //icon color
				@media (prefers-reduced-motion: no-preference) {transition: all 0.3s;}
			}
		}
	}

	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#rss-icon {
			margin: 0;
			position: relative;
			top: auto;
			right: auto;
			transform: none;

			&:hover {
				cursor: pointer;
			}
		}
	}

	//animations
	/*@media (prefers-reduced-motion: no-preference) {
