---
// Utils
import { Icon } from "astro-icon/components";
import { isCurrentPage, getDropdownId } from "@js/utils.js";

// Data
import navData from "@data/navData.json";

import { getCurrentYear } from "@js/utils";
const currentYear = getCurrentYear();
---

<footer id="footer">
	<div class="cs-container">
		<div class="cs-top">
			<div class="cs-sitenav">
					<a href="/" class="cs-logo" aria-label="Return to home page">
						<span id="logo-text">Anna Grace</span>
					</a>
			</div>
			<div class="cs-sitenav">
				<ul class="cs-ul">
					{
						navData.map((entry) => (
							<li
								class:list={[
									"cs-li",
									{ "cs-dropdown": entry.children?.length > 0 },
								]}
							>
								{entry.children?.length > 0 ? (
									// If entry has children in navData.json, create a button and a dropdown icon
									// can link to folder as well
									<a href={entry.url} class:list={[
											"cs-li-nav",
											{ "menu-active": Astro.url.pathname === (entry.url) },
										]}>
										{entry.key}
									</a>
								) : (
									// If entry does not have children in navData.json, create an anchor
									<a href={entry.url} class:list={[
											"cs-link",
											{ "menu-active": Astro.url.pathname === (entry.url) },
										]}>
										{entry.key}
									</a>
								)}

								{entry.children?.length > 0 && (
									// If entry has children in navData.json, create a drop down menu
									<ul
										class="cs-link"
										aria-labelledby={getDropdownId(entry.key)}
									>
										{entry.children.map((child) => (
											<li class="cs-drop-li">
												<a href={child.url} class="cs-link">
													{child.key}
												</a>
											</li>
										))}
									</ul>
								)}
							</li>
						))
					}
					<li class="cs-li">
						<a href="/contact/" class:list={[
											"cs-link",
											{ "menu-active": Astro.url.pathname === "/contact/" },
										]}> Contact </a>
					</li>
				</ul>
			</div>
		</div>
		<div class="cs-bottom">
			<!--Social
			<ul class="cs-social">
				<li class="cs-social-li">
					<a
						href=""
						class="cs-social-link"
						aria-label="facebook"
						target="_blank"
						rel="noopener"
					>
						<img
							class="cs-social-icon cs-default"
							src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/facebook-white.svg"
							alt="icon"
							loading="lazy"
							decoding="async"
							width="12"
							height="12"
							aria-hidden="true"
						/>
					</a>
				</li>
				<li class="cs-social-li">
					<a
						href=""
						class="cs-social-link"
						aria-label="twitter"
						target="_blank"
						rel="noopener"
					>
						<img
							class="cs-social-icon cs-default"
							src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/twitter-white.svg"
							alt="icon"
							loading="lazy"
							decoding="async"
							width="12"
							height="12"
							aria-hidden="true"
						/>
					</a>
				</li>
				<li class="cs-social-li">
					<a
						href=""
						class="cs-social-link"
						aria-label="instagram"
						target="_blank"
						rel="noopener"
					>
						<img
							class="cs-social-icon cs-default"
							src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/instagram-transparent.svg"
							alt="icon"
							loading="lazy"
							decoding="async"
							width="12"
							height="12"
							aria-hidden="true"
						/>
					</a>
				</li>
				<li class="cs-social-li">
					<a
						href=""
						class="cs-social-link"
						aria-label="twitter"
						target="_blank"
						rel="noopener"
					>
						<img
							class="cs-social-icon cs-default"
							src="https://csimg.nyc3.cdn.digitaloceanspaces.com/Icons/youtube-transparent2.svg"
							alt="icon"
							loading="lazy"
							decoding="async"
							width="12"
							height="12"
							aria-hidden="true"
						/>
					</a>
				</li>
			</ul>-->
			<div class="cs-copyright">
				<span>© <a href="https://annagrace.dev" class="cs-copyright-link"
						>Anna Grace Cooper</a
					> {currentYear}. All rights reserved.</span>
			</div>
		</div>
	</div>
	<picture class="cs-background">
	</picture>
</footer>

<style lang="less">

	/* Mobile - 360px */
	@media only screen and (min-width: 0rem) {
		#footer {
			padding: var(--sectionPadding);
			position: relative;
			z-index: 1;
			font-style: normal;
			font-family: "Overpass", sans-serif;
			font-size: clamp(0.875rem,1.5vw,1rem);

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				display: flex;
				flex-direction: column;
				align-items: center;
			}

			.cs-top {
				width: 100%;
				/* 32px - 40px */
				margin-bottom: clamp(2rem, 4vw, 2.5rem);
				padding-bottom: clamp(2rem, 4vw, 2.5rem);
				// border-bottom: 1px solid #484848;
				display: flex;
				flex-direction: column;
				align-items: flex-start;
				justify-content: center;
				gap: (32/16rem);
			}

			.cs-sitenav {
				flex-grow: 1;
			}

			.cs-ul {
				margin: 0;
				padding: 0;
				display: flex;
				flex-wrap: wrap;
				align-items: flex-start;
				justify-content: space-between;
				row-gap: (8/16rem);
				/* 28px - 40px */
				column-gap: clamp(1.75rem, 4vw, 2.5rem);
			}

			.cs-li,
			.cs-li * {
				list-style: none;
				padding-inline-start: 0;
				line-height: 1.5;
				font-family: "Overpass", sans-serif;
				font-size: clamp(0.875rem, 1vw, 1rem);
				font-weight: 400;
			}	

			.cs-li-nav {
				font-weight: bold;
				text-decoration: none;
				font-size: clamp(0.875rem, 1.5vw, 1rem);
				color: var(--gray);
				@media screen (prefers-reduced-motion: no-preference) {
					transition: color 0.3s ease-in-out;
				}
				cursor: auto;
				/*&:hover {
					color: var(--secondary);
				} uncomment if menu folders are pages */
			}

			.cs-link {
				/* 14px - 16px */
				font-size: clamp(0.875rem, 1.5vw, 1rem);
				line-height: 1.5em;
				text-decoration: none;
				margin: 0;
				color: var(--gray);
				display: block;
				@media screen (prefers-reduced-motion: no-preference) {
					transition: color 0.3s ease-in-out;
				}

				&:hover {
					color: var(--secondary);
				}
			}

			.menu-active {
				// text-decoration: underline;
			}

			.cs-logo {
				display: flex;
				gap: 0.5rem; 
				text-decoration: none;
				color: var(--gray);
				&:hover {
						color: var(--secondary);
					}
				#logo-img {
					position: relative;
					top: 0rem;
					width: 1rem;
					height: auto;
					display: block;
				}
				#logo-text {
					font-family: "Overpass", sans-serif;
					/* 16px - 24px */
					font-size: clamp(0.875rem, 1.5vw, 1rem);
					font-style: normal;
				}
			}

			.cs-bottom {
				width: 100%;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: (24/16rem);
			}

			.cs-social {
				margin: 0;
				padding: 0;
				display: flex;
				justify-content: center;
				align-items: center;
				gap: (8/16rem);
			}

			.cs-social-li {
				list-style: none;
			}

			.cs-social-link {
				width: (32/16rem);
				height: (32/16rem);
				background-color: #484848;
				border-radius: 50%;
				display: flex;
				justify-content: center;
				align-items: center;
				transition: background-color 0.3s ease-in-out;
				&:hover {
					background-color: var(--secondary);

					.cs-social-icon {
						filter: grayscale(1) brightness(0);
						opacity: 1;
					}
				}
			}

			.cs-social-icon {
				width: (12/16rem);
				height: auto;
				display: block;
				opacity: 0.5;
			}

			.cs-copyright {
				//font-size: (16/16rem);
				line-height: 1.5em;
				margin: 0;
				color: var(--gray);
				display: block;
				font-weight: 400;
			}

			.cs-copyright-link {
				//font-size: inherit;
				text-decoration: none;
				color: var(--gray);

				&:hover {
					color: var(--secondary);
				}
			}

			.cs-background {
				width: 100%;
				height: 100%;
				display: block;
				position: absolute;
				top: 0;
				left: 0;
				z-index: -1;

				&:before {
					/* background color overlay */
					content: "";
					position: absolute;
					display: block;
					height: 100%;
					width: 100%;
					background: #1a1a1a;
					opacity: 0.96;
					top: 0;
					left: 0;
					z-index: 1;
				}

				img {
					position: absolute;
					top: 0;
					left: 0;
					height: 100%;
					width: 100%;
					/* Makes img tag act as a background image */
					object-fit: cover;
				}
			}
		}
	}

	/* Tablet - 768px */
	@media only screen and (min-width: 48rem) {
		#footer {
			.cs-top {
				flex-direction: row;
				justify-content: space-between;
			}

			.cs-bottom {
				flex-direction: row;
				justify-content: space-between;
			}
		}
	}
</style>
